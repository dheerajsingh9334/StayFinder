{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",

    "outDir": "dist",
    "rootDir": ".",

    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "types": ["node", "express"],
    "lib": ["ES2020"],

    "skipLibCheck": true
  },
  "include": ["server.ts", "src/**/*.ts", "prisma/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
