{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/cluster.js",
  "scripts": {
    "dev": "concurrently -n \"WEB,WORKER,AI\" -c \"blue,green,magenta\" \"npm run dev:web\" \"npm run dev:worker\" \"npm run dev:worker:ai\"",
    "dev:web": "tsx watch server.ts",
    "dev:worker": "concurrently -n \"EMAIL,BOOKING,PAYMENT\" -c \"cyan,yellow,red\" \"tsx watch src/workers/email.worker.ts\" \"tsx watch src/workers/booking.worker.ts\" \"tsx watch src/workers/payment.worker.ts\"",
    "dev:worker:ai": "tsx watch src/workers/ai.worker.ts",
    "build": "tsc",
    "start": "npm run start:web",
    "start:all": "concurrently \"npm run start:web\" \"npm run start:worker\" \"npm run start:worker:ai\"",
    "start:web": "node dist/cluster.js",
    "start:worker": "concurrently \"node dist/src/workers/email.worker.js\" \"node dist/src/workers/booking.worker.js\" \"node dist/src/workers/payment.worker.js\"",
    "start:worker:ai": "node dist/src/workers/ai.worker.js",
    "start:workeer:index": "START_WORKERS=true node dist/cluster.js"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/express-rate-limit": "^5.1.3",
    "@types/helmet": "^0.0.48",
    "@types/socket.io": "^3.0.1",
    "prisma": "^6.19.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@pinecone-database/pinecone": "^7.1.0",
    "@prisma/client": "^6.19.0",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "@types/nodemailer": "^7.0.11",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.71.0",
    "compression": "^1.8.1",
    "concurrently": "^9.2.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.0.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
